<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Autonomous cargo drone. STUB: a small, fast, long-range, low-cargo buildable shuttle so it's
       in the lineup + testable now. The autonomous behaviour (0-crew launch, gift-at-settlement,
       strand-if-low-fuel) is the later C# phase; for now it flies like a normal player shuttle. -->
  <ThingDef ParentName="OSV_ShuttleBase">
    <defName>OSV_DroneShuttle</defName>
    <label>transport drone</label>
    <description>A small autonomous cargo drone for long-range, hands-off deliveries. (Full autonomous behaviour arrives in a later update; for now it flies like a standard shuttle.)</description>
    <constructionSkillPrerequisite>5</constructionSkillPrerequisite>
    <statBases>
      <WorkToBuild>26000</WorkToBuild>
    </statBases>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Things/Building/OSV/DroneShuttle/DroneShuttle</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2.4,5)</drawSize>
      <shadowData>
        <volume>(1.2, 1.0, 3.5)</volume>
      </shadowData>
    </graphicData>
    <costList>
      <Steel>150</Steel>
      <Plasteel>90</Plasteel>
      <ComponentIndustrial>6</ComponentIndustrial>
      <ShuttleEngine>1</ShuttleEngine>
    </costList>
    <researchPrerequisites>
      <li>OSV_DroneShuttleTech</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Shuttle">
        <shipDef>Ship_OSV_DroneShuttle</shipDef>
      </li>
      <li Class="OdysseyShuttleVariants.CompProperties_TypedShuttleCapacity">
        <noPawns>true</noPawns>
      </li>
      <li Class="CompProperties_Launchable">
        <fuelPerTile>1.5</fuelPerTile>
        <minFuelCost>30</minFuelCost>
        <skyfallerLeaving>OSV_DroneShuttleLeaving</skyfallerLeaving>
        <worldObjectDef>OSV_TravelingShuttle</worldObjectDef>
        <cooldownTicks>1500</cooldownTicks>
        <fixedLaunchDistanceMax>200</fixedLaunchDistanceMax>
        <cooldownEndedMessage>{0} is ready to launch again.</cooldownEndedMessage>
      </li>
      <li Class="CompProperties_Transporter">
        <massCapacity>500</massCapacity>
        <max1PerGroup>true</max1PerGroup>
        <canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
        <pawnLoadedSound>Shuttle_PawnLoaded</pawnLoadedSound>
        <pawnExitSound>Shuttle_PawnExit</pawnExitSound>
        <showMassInInspectString>true</showMassInInspectString>
      </li>
      <li Class="CompProperties_Refuelable">
        <fuelCapacity>500</fuelCapacity>
        <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <initialConfigurableTargetFuelLevel>500</initialConfigurableTargetFuelLevel>
        <fuelFilter><thingDefs><li>Chemfuel</li></thingDefs></fuelFilter>
        <fuelLabel>Chemfuel</fuelLabel>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <autoRefuelPercent>1</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <drawOutOfFuelOverlay>false</drawOutOfFuelOverlay>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <canEjectFuel>true</canEjectFuel>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="OSV_ShuttleIncomingBase">
    <defName>OSV_DroneShuttleIncoming</defName>
    <label>transport drone (incoming)</label>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Things/Building/OSV/DroneShuttle/DroneShuttle</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2.4,5)</drawSize>
    </graphicData>
  </ThingDef>
  <ThingDef ParentName="OSV_ShuttleLeavingBase">
    <defName>OSV_DroneShuttleLeaving</defName>
    <label>transport drone (leaving)</label>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Things/Building/OSV/DroneShuttle/DroneShuttle</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2.4,5)</drawSize>
    </graphicData>
  </ThingDef>

  <TransportShipDef>
    <defName>Ship_OSV_DroneShuttle</defName>
    <label>transport drone</label>
    <shipThing>OSV_DroneShuttle</shipThing>
    <arrivingSkyfaller>OSV_DroneShuttleIncoming</arrivingSkyfaller>
    <leavingSkyfaller>OSV_DroneShuttleLeaving</leavingSkyfaller>
    <worldObject>OSV_TravelingShuttle</worldObject>
    <playerShuttle>true</playerShuttle>
  </TransportShipDef>

  <ResearchProjectDef>
    <defName>OSV_DroneShuttleTech</defName>
    <label>transport drone</label>
    <description>Autonomous flight control and lightweight drone frames, enabling construction of the transport drone.</description>
    <baseCost>2500</baseCost>
    <techLevel>Spacer</techLevel>
    <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
    <requiredResearchFacilities>
      <li>MultiAnalyzer</li>
    </requiredResearchFacilities>
    <prerequisites>
      <!-- Drone hangs off the Mech shuttle (autonomous flight builds on mech control tech).
           Mech is Biotech-only, so this makes the Drone require Biotech too - intended. -->
      <li>OSV_MechShuttleTech</li>
    </prerequisites>
    <tab>OSV_ShuttlesTab</tab>
    <researchViewX>3.0</researchViewX>
    <researchViewY>2.5</researchViewY>
  </ResearchProjectDef>

</Defs>
