<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- ============ shared base for our buildable shuttles ============ -->
  <!-- Each concrete shuttle supplies its own graphicData (its own cloned art folder) and its
       own skyfallers, so every craft is fully self-contained and can be re-skinned independently. -->
  <ThingDef Name="OSV_ShuttleBase" ParentName="BuildingBase" Abstract="True">
    <thingClass>Building_PassengerShuttle</thingClass>
    <altitudeLayer>Building</altitudeLayer>
    <preventDroppingThingsOn>true</preventDroppingThingsOn>
    <pathCost>50</pathCost>
    <blockWind>true</blockWind>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.9</fillPercent>
    <size>(3,5)</size>
    <rotatable>true</rotatable>
    <defaultPlacingRot>East</defaultPlacingRot>
    <designationCategory>Odyssey</designationCategory>
    <tickerType>Normal</tickerType>
    <canOverlapZones>true</canOverlapZones>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <drawerType>RealtimeOnly</drawerType>
    <repairEffect>ConstructMetal</repairEffect>
    <preventSkyfallersLandingOn>true</preventSkyfallersLandingOn>
    <forceDebugSpawnable>true</forceDebugSpawnable>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(2, 0, 0)</interactionCellOffset>
    <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
    <statBases>
      <MaxHitPoints>700</MaxHitPoints>
      <Flammability>0.5</Flammability>
      <Comfort>0.65</Comfort>
    </statBases>
    <building>
      <claimable>false</claimable>
      <destroySound>BuildingDestroyed_Metal_Big</destroySound>
      <paintable>true</paintable>
      <isInert>true</isInert>
      <forcedCostLeavings>
        <li MayRequire="Ludeon.RimWorld.Odyssey">ShuttleEngine</li>
      </forcedCostLeavings>
    </building>
    <inspectorTabs>
      <li>ITab_ContentsTransporter</li>
    </inspectorTabs>
    <comps>
      <li Class="CompProperties_AmbientSound">
        <sound>ShuttleIdle_Ambience</sound>
      </li>
    </comps>
  </ThingDef>

  <!-- abstract skyfaller bases that just carry the right thingClass; concrete ones set the art -->
  <ThingDef Name="OSV_ShuttleIncomingBase" ParentName="ShuttleSkyfallerBase" Abstract="True">
    <thingClass>PassengerShuttleIncoming</thingClass>
    <skyfaller>
      <anticipationSound>Shuttle_Landing</anticipationSound>
      <anticipationSoundTicks>200</anticipationSoundTicks>
      <ticksToImpactRange>160~200</ticksToImpactRange>
      <minimalRoofDestruction>true</minimalRoofDestruction>
      <shadowSize>(3.5,5.5)</shadowSize>
      <!-- ShuttleSkyfallerBase doesn't define these; PassengerShuttleIncoming.GetDrawPositionAndRotation
           dereferences them every frame, so they MUST be set or the landing animation NREs. Copied from
           vanilla PassengerShuttleIncoming. -->
      <rotationCurve>
        <points>
          <li>(0,30)</li>
          <li>(0.5,5)</li>
          <li>(0.9,-5)</li>
          <li>(0.95,0)</li>
        </points>
      </rotationCurve>
      <zPositionCurve>
        <points>
          <li>(0.95,2.5)</li>
          <li>(1,0)</li>
        </points>
      </zPositionCurve>
      <speedCurve>
        <points>
          <li>(0.6,0.6)</li>
          <li>(0.95,0.1)</li>
        </points>
      </speedCurve>
    </skyfaller>
  </ThingDef>
  <ThingDef Name="OSV_ShuttleLeavingBase" ParentName="ShuttleSkyfallerBase" Abstract="True">
    <thingClass>PassengerShuttleLeaving</thingClass>
    <rotatable>true</rotatable>
    <skyfaller>
      <reversed>true</reversed>
      <anticipationSound>Shuttle_Leaving</anticipationSound>
      <anticipationSoundTicks>-8</anticipationSoundTicks>
      <ticksToImpactRange>-30~-12</ticksToImpactRange>
      <moteSpawnTime>0.05</moteSpawnTime>
      <shadow>Things/Skyfaller/SkyfallerShadowRectangle</shadow>
      <shadowSize>(3.5,5.5)</shadowSize>
      <motesPerCell>1</motesPerCell>
      <!-- ShuttleSkyfallerBase doesn't define these; PassengerShuttleLeaving.GetDrawPositionAndRotation
           dereferences them every frame, so they MUST be set or the launch animation NREs. Copied from
           vanilla PassengerShuttleLeaving. -->
      <rotationCurve>
        <points>
          <li>(0,0)</li>
          <li>(0.15,10)</li>
          <li>(0.5,-5)</li>
        </points>
      </rotationCurve>
      <zPositionCurve>
        <points>
          <li>(0,0)</li>
          <li>(0.08,2)</li>
        </points>
      </zPositionCurve>
      <speedCurve>
        <points>
          <li>(0,0.2)</li>
          <li>(0.4,0.7)</li>
        </points>
      </speedCurve>
    </skyfaller>
  </ThingDef>

  <!-- =================== Cargo Shuttle =================== -->
  <ThingDef ParentName="OSV_ShuttleBase">
    <defName>OSV_CargoShuttle</defName>
    <label>cargo shuttle</label>
    <description>A heavy-lift transport shuttle built around an oversized cargo hold. It carries far more mass than a standard shuttle at the cost of slower turnaround and thirstier engines.</description>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <!-- Footprint hugs the sprite so the selection box sits tight on the hull (like vanilla).
         drawSize 4.3x6.6 only hugs at width 4 (odd 3 overflows, 5 is loose) - so this is even,
         the one craft where we trade the odd-rotation rule for a tight box. Watch E/W rotation. -->
    <size>(4,6)</size>
    <!-- even width 4 -> east edge at x=2, so the side boarding cell sits at x=3, just off the hull. -->
    <interactionCellOffset>(3,0,0)</interactionCellOffset>
    <statBases>
      <WorkToBuild>40000</WorkToBuild>
    </statBases>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Things/Building/OSV/CargoShuttle/CargoShuttle</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(4.3,6.6)</drawSize>
      <shadowData>
        <volume>(1.2, 1.0, 3.5)</volume>
      </shadowData>
    </graphicData>
    <!-- drawSize 6.6 vs 4x6 footprint overflows the architect button ~1.1x; 0.9 brings it to ~0.99. -->
    <uiIconScale>0.9</uiIconScale>
    <costList>
      <Steel>300</Steel>
      <Plasteel>200</Plasteel>
      <ComponentIndustrial>10</ComponentIndustrial>
      <ShuttleEngine>2</ShuttleEngine>
    </costList>
    <researchPrerequisites>
      <li>OSV_CargoShuttleTech</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Shuttle">
        <shipDef>Ship_OSV_CargoShuttle</shipDef>
      </li>
      <li Class="OdysseyShuttleVariants.CompProperties_TypedShuttleCapacity">
        <maxColonists>2</maxColonists>
      </li>
      <li Class="CompProperties_Launchable">
        <fuelPerTile>3.2</fuelPerTile>
        <minFuelCost>55</minFuelCost>
        <skyfallerLeaving>OSV_CargoShuttleLeaving</skyfallerLeaving>
        <worldObjectDef>OSV_TravelingShuttle</worldObjectDef>
        <cooldownTicks>3000</cooldownTicks>
        <fixedLaunchDistanceMax>85</fixedLaunchDistanceMax>
        <cooldownEndedMessage>{0} is ready to launch again.</cooldownEndedMessage>
      </li>
      <li Class="CompProperties_Transporter">
        <massCapacity>1250</massCapacity>
        <max1PerGroup>true</max1PerGroup>
        <canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
        <pawnLoadedSound>Shuttle_PawnLoaded</pawnLoadedSound>
        <pawnExitSound>Shuttle_PawnExit</pawnExitSound>
        <showMassInInspectString>true</showMassInInspectString>
      </li>
      <li Class="CompProperties_Refuelable">
        <fuelCapacity>600</fuelCapacity>
        <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <initialConfigurableTargetFuelLevel>600</initialConfigurableTargetFuelLevel>
        <fuelFilter><thingDefs><li>Chemfuel</li></thingDefs></fuelFilter>
        <fuelLabel>Chemfuel</fuelLabel>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <autoRefuelPercent>1</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <drawOutOfFuelOverlay>false</drawOutOfFuelOverlay>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <canEjectFuel>true</canEjectFuel>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="OSV_ShuttleIncomingBase">
    <defName>OSV_CargoShuttleIncoming</defName>
    <label>cargo shuttle (incoming)</label>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Things/Building/OSV/CargoShuttle/CargoShuttle</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(4.3,6.6)</drawSize>
    </graphicData>
  </ThingDef>
  <ThingDef ParentName="OSV_ShuttleLeavingBase">
    <defName>OSV_CargoShuttleLeaving</defName>
    <label>cargo shuttle (leaving)</label>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Things/Building/OSV/CargoShuttle/CargoShuttle</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(4.3,6.6)</drawSize>
    </graphicData>
  </ThingDef>

  <TransportShipDef>
    <defName>Ship_OSV_CargoShuttle</defName>
    <label>cargo shuttle</label>
    <shipThing>OSV_CargoShuttle</shipThing>
    <arrivingSkyfaller>OSV_CargoShuttleIncoming</arrivingSkyfaller>
    <leavingSkyfaller>OSV_CargoShuttleLeaving</leavingSkyfaller>
    <worldObject>OSV_TravelingShuttle</worldObject>
    <playerShuttle>true</playerShuttle>
  </TransportShipDef>

  <!-- =================== Troop Shuttle =================== -->
  <ThingDef ParentName="OSV_ShuttleBase">
    <defName>OSV_TroopShuttle</defName>
    <label>troop shuttle</label>
    <description>A fast personnel shuttle tuned for rapid insertion and extraction. It trades raw cargo capacity for speed and range.</description>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <statBases>
      <WorkToBuild>34000</WorkToBuild>
    </statBases>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Things/Building/OSV/TroopShuttle/TroopShuttle</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2.4,5)</drawSize>
      <shadowData>
        <volume>(1.2, 1.0, 3.5)</volume>
      </shadowData>
    </graphicData>
    <costList>
      <Steel>220</Steel>
      <Plasteel>140</Plasteel>
      <ComponentIndustrial>8</ComponentIndustrial>
      <ShuttleEngine>1</ShuttleEngine>
    </costList>
    <researchPrerequisites>
      <li>OSV_TroopShuttleTech</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Shuttle">
        <shipDef>Ship_OSV_TroopShuttle</shipDef>
      </li>
      <li Class="OdysseyShuttleVariants.CompProperties_TypedShuttleCapacity">
        <!-- the squad-hauler: high crew. 12 clears a 10-colonist quest with headroom. -->
        <maxColonists>12</maxColonists>
      </li>
      <li Class="CompProperties_Launchable">
        <fuelPerTile>2.2</fuelPerTile>
        <minFuelCost>40</minFuelCost>
        <skyfallerLeaving>OSV_TroopShuttleLeaving</skyfallerLeaving>
        <worldObjectDef>OSV_TravelingShuttle</worldObjectDef>
        <cooldownTicks>2000</cooldownTicks>
        <fixedLaunchDistanceMax>120</fixedLaunchDistanceMax>
        <cooldownEndedMessage>{0} is ready to launch again.</cooldownEndedMessage>
      </li>
      <li Class="CompProperties_Transporter">
        <massCapacity>100</massCapacity>
        <max1PerGroup>true</max1PerGroup>
        <canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
        <pawnLoadedSound>Shuttle_PawnLoaded</pawnLoadedSound>
        <pawnExitSound>Shuttle_PawnExit</pawnExitSound>
        <showMassInInspectString>true</showMassInInspectString>
      </li>
      <li Class="CompProperties_Refuelable">
        <fuelCapacity>550</fuelCapacity>
        <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <initialConfigurableTargetFuelLevel>550</initialConfigurableTargetFuelLevel>
        <fuelFilter><thingDefs><li>Chemfuel</li></thingDefs></fuelFilter>
        <fuelLabel>Chemfuel</fuelLabel>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <autoRefuelPercent>1</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <drawOutOfFuelOverlay>false</drawOutOfFuelOverlay>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <canEjectFuel>true</canEjectFuel>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="OSV_ShuttleIncomingBase">
    <defName>OSV_TroopShuttleIncoming</defName>
    <label>troop shuttle (incoming)</label>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Things/Building/OSV/TroopShuttle/TroopShuttle</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2.4,5)</drawSize>
    </graphicData>
  </ThingDef>
  <ThingDef ParentName="OSV_ShuttleLeavingBase">
    <defName>OSV_TroopShuttleLeaving</defName>
    <label>troop shuttle (leaving)</label>
    <graphicData>
      <graphicClass>Graphic_Multi</graphicClass>
      <texPath>Things/Building/OSV/TroopShuttle/TroopShuttle</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2.4,5)</drawSize>
    </graphicData>
  </ThingDef>

  <TransportShipDef>
    <defName>Ship_OSV_TroopShuttle</defName>
    <label>troop shuttle</label>
    <shipThing>OSV_TroopShuttle</shipThing>
    <arrivingSkyfaller>OSV_TroopShuttleIncoming</arrivingSkyfaller>
    <leavingSkyfaller>OSV_TroopShuttleLeaving</leavingSkyfaller>
    <worldObject>OSV_TravelingShuttle</worldObject>
    <playerShuttle>true</playerShuttle>
  </TransportShipDef>

</Defs>
