<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Unlock chain: TransportPod + MultiAnalyzer -> Troop -> Cargo -> Drone. Mech branches off
       TransportPod + StandardMechtech (parallel; in the Biotech file). Per-shuttle capacity-UPGRADE
       projects (cargo / fuel eff / range / crew-mech cap) are a later C# phase (stats read research). -->

  <ResearchProjectDef>
    <defName>OSV_CargoShuttleTech</defName>
    <label>cargo shuttle</label>
    <description>Reinforced cargo frames and high-capacity transporter racks, enabling construction of the cargo shuttle.</description>
    <baseCost>2500</baseCost>
    <techLevel>Spacer</techLevel>
    <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
    <requiredResearchFacilities>
      <li>MultiAnalyzer</li>
    </requiredResearchFacilities>
    <prerequisites>
      <li>OSV_TroopShuttleTech</li>
    </prerequisites>
    <tab>OSV_ShuttlesTab</tab>
    <researchViewX>2.5</researchViewX>
    <researchViewY>1.0</researchViewY>
  </ResearchProjectDef>

  <ResearchProjectDef>
    <defName>OSV_HeavyCargoShipTech</defName>
    <label>heavy cargo ship</label>
    <description>Oversized airframes, quad-engine mounts and reinforced load-bearing decks, enabling construction of the heavy cargo ship.</description>
    <baseCost>4000</baseCost>
    <techLevel>Spacer</techLevel>
    <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
    <requiredResearchFacilities>
      <li>MultiAnalyzer</li>
    </requiredResearchFacilities>
    <prerequisites>
      <li>OSV_CargoShuttleTech</li>
    </prerequisites>
    <tab>OSV_ShuttlesTab</tab>
    <researchViewX>4.5</researchViewX>
    <researchViewY>1.0</researchViewY>
  </ResearchProjectDef>

  <ResearchProjectDef>
    <defName>OSV_TroopShuttleTech</defName>
    <label>troop shuttle</label>
    <description>Lightweight airframes and rapid-cycle launch systems, enabling construction of the troop shuttle.</description>
    <baseCost>2500</baseCost>
    <techLevel>Spacer</techLevel>
    <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
    <requiredResearchFacilities>
      <li>MultiAnalyzer</li>
    </requiredResearchFacilities>
    <prerequisites>
      <li>TransportPod</li>
      <li>MultiAnalyzer</li>
    </prerequisites>
    <tab>OSV_ShuttlesTab</tab>
    <researchViewX>0.5</researchViewX>
    <researchViewY>1.0</researchViewY>
  </ResearchProjectDef>

</Defs>
