<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Makes the vanilla ShuttleEngine craftable (vanilla = trader/reward only), so shuttles can be
       built self-sufficiently. Field values mirror the vanilla Make_ComponentSpacer fabrication recipe.
       NOTE: tiered engines (Mk2/Mk3) that change shuttle stats are a later C# phase — they need the
       shuttle to read an installed engine, which XML alone can't express. -->

  <RecipeDef>
    <defName>OSV_Make_ShuttleEngine</defName>
    <label>make shuttle engine</label>
    <description>Fabricate a shuttle engine from plasteel, advanced components and uranium.</description>
    <jobString>Making a shuttle engine.</jobString>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_Machining</soundWorking>
    <workAmount>22000</workAmount>
    <unfinishedThingDef>UnfinishedComponent</unfinishedThingDef>
    <ingredients>
      <li>
        <filter><thingDefs><li>Plasteel</li></thingDefs></filter>
        <count>75</count>
      </li>
      <li>
        <filter><thingDefs><li>ComponentSpacer</li></thingDefs></filter>
        <count>4</count>
      </li>
      <li>
        <filter><thingDefs><li>Uranium</li></thingDefs></filter>
        <count>15</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>ComponentSpacer</li>
        <li>Uranium</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <ShuttleEngine>1</ShuttleEngine>
    </products>
    <skillRequirements>
      <Crafting>8</Crafting>
    </skillRequirements>
    <workSkill>Crafting</workSkill>
    <recipeUsers>
      <li>FabricationBench</li>
    </recipeUsers>
    <researchPrerequisite>OSV_ShuttleEngineFabrication</researchPrerequisite>
    <displayPriority>100</displayPriority>
  </RecipeDef>

  <ResearchProjectDef>
    <defName>OSV_ShuttleEngineFabrication</defName>
    <label>shuttle engine fabrication</label>
    <description>Miniaturized plasma-drive assembly techniques, allowing shuttle engines to be fabricated in-house instead of bought from orbital traders.</description>
    <baseCost>3000</baseCost>
    <techLevel>Spacer</techLevel>
    <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
    <requiredResearchFacilities>
      <li>MultiAnalyzer</li>
    </requiredResearchFacilities>
    <prerequisites>
      <li>Shuttles</li>
      <li>Fabrication</li>
    </prerequisites>
    <tab>OSV_ShuttlesTab</tab>
    <researchViewX>1.0</researchViewX>
    <researchViewY>3.5</researchViewY>
  </ResearchProjectDef>

</Defs>
